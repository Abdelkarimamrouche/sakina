  "about_title":                  { "message": "About Sakina" },
  "about_what_title":             { "message": "What is Sakina?" },
  "about_what_body":              { "message": "Sakina is a free Chrome extension that automatically detects and mutes music on YouTube, Instagram, Facebook, and TikTok using on-device AI. Speech, Quran recitation, and ambient sounds always play normally — only music is muted." },
  "about_why_title":              { "message": "Why was it created?" },
  "about_why_body":               { "message": "This extension was created as a gift for the Muslim community. Many of us want to benefit from useful videos without having music enter our hearts. The heart cannot hold both the Quran and music — so this tool was built to protect it.\n\nNo subscription. No account. No data collected. Free for every Muslim in the world, for the sake of Allah." },
  "about_dua_title":              { "message": "A Request" },
  "about_dua_body":               { "message": "I ask for nothing in return except your Dua. If this extension has benefited you, please make Dua for me, my family, and all Muslims. Ask Allah to accept this small deed and to keep our hearts firm.\n\nMay Allah make it a source of good on the Day when deeds will matter most." },
  "about_dua_arabic":             { "message": "اللَّهُمَّ تَقَبَّل مِنَّا" },
  "about_dua_arabic_meaning":     { "message": "O Allah, accept from us." },
