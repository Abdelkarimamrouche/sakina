{
  "name": "sakina",
  "version": "1.5.10",
  "description": "Sakina — auto mute music extension for the Muslim community",
  "private": true,
  "scripts": {
    "dev": "webpack --config webpack.config.js --mode development --watch",
    "build": "webpack --config webpack.config.js --mode production",
    "build:dev": "webpack --config webpack.config.js --mode development",
    "icons": "node scripts/generate-icons.js",
    "lint": "eslint src/**/*.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "package": "npm run build && node scripts/package.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.17.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.53.0",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "mini-css-extract-plugin": "^2.7.6",
    "sharp": "^0.34.5",
    "style-loader": "^3.3.3",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "zip-webpack-plugin": "^4.0.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/src/__tests__/**/*.test.js"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverageFrom": [
      "src/shared/**/*.js",
      "src/content/MuteController.js",
      "src/content/YamNetClassifier.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 40,
        "functions": 40,
        "lines": 40,
        "statements": 40
      }
    }
  },
  "browserslist": [
    "last 2 Chrome versions"
  ]
}
